# PostgreSQL ulanish sozlamalari
PGHOST=localhost
PGUSER=postgres
PGPASSWORD=your_password_here
PGDATABASE=ulgurji_savdo
PGPORT=5432

# JWT sozlamalari — kamida 32 belgili, tasodifiy kalit ishlatilsin!
JWT_SECRET=change_this_to_a_very_long_random_secret_key
JWT_EXPIRES_IN=24h

# Server port
PORT=5000

# CORS — ruxsat berilgan frontendlar (vergul bilan ajratib bir nechta yozish mumkin)
# Ishlab chiqarishda: https://yourdomain.com
ALLOWED_ORIGIN=http://localhost:3000

# Clerk authentication (https://clerk.com dan oling)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
